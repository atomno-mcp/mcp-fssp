# ---------------------------------------------------------------------------
# mcp-fssp — пример конфигурации.
# Скопируй в .env и заполни нужные секции для выбранного провайдера.
# ---------------------------------------------------------------------------

# Какой провайдер использовать по умолчанию.
# Допустимые значения: damia | newdb | checko | api_cloud | self_parser | atomno_pro
# По умолчанию: damia (баланс цена/качество, см. SPEC §1.3 и §10).
MCP_FSSP_PROVIDER=damia

# ---------------------------------------------------------------------------
# Damia API-ФССП (https://api-fssp.damia.ru)
# Тариф: от 7 000 ₽/год за 1 000 запросов; 100 запросов бесплатно на тест.
# ---------------------------------------------------------------------------
MCP_FSSP_DAMIA_KEY=

# ---------------------------------------------------------------------------
# Checko API v2 (https://api.checko.ru)
# До 50 запросов/день бесплатно.
# ---------------------------------------------------------------------------
MCP_FSSP_CHECKO_KEY=

# ---------------------------------------------------------------------------
# NewDB.net (https://newdb.net/fssp/api)
# 100 запросов бесплатно, далее 2 ₽/запрос.
# ---------------------------------------------------------------------------
MCP_FSSP_NEWDB_KEY=

# ---------------------------------------------------------------------------
# api-cloud.ru (https://api-cloud.ru/api/fssp.php)
# Per-request оплата.
# ---------------------------------------------------------------------------
MCP_FSSP_API_CLOUD_KEY=

# ---------------------------------------------------------------------------
# Pro-режим (api.atomno-mcp.ru/fssp/) — multi-provider fallback, кэш 30 дней,
# AI-summary и подписка на изменения.
# Получить ключ можно после регистрации на https://atomno-mcp.ru/fssp (когда сервис
# выйдет в публичный bета — Phase 3 roadmap'а).
# ---------------------------------------------------------------------------
ATOMNO_API_KEY=
ATOMNO_API_BASE=https://api.atomno-mcp.ru/mcp-fssp/v1

# ---------------------------------------------------------------------------
# HTTP / лимиты.
# ---------------------------------------------------------------------------

# Таймаут одного провайдерского запроса в секундах. Default 15.
MCP_FSSP_HTTP_TIMEOUT=15

# Максимум запросов в минуту со стороны клиента (rate-limit). Default 30.
MCP_FSSP_RPS=30

# User-Agent заголовок для запросов к провайдерам.
MCP_FSSP_USER_AGENT=mcp-fssp/0.1 (+https://github.com/atomno-mcp/mcp-fssp)

# ---------------------------------------------------------------------------
# Локальный аудит-лог (SQLite). ПДн (ФИО+ДР) хэшируются sha256, в plain-text
# не сохраняются — см. SPEC §7.7.
# ---------------------------------------------------------------------------
MCP_FSSP_AUDIT_DB=./audit.sqlite

# Уровень логирования: DEBUG | INFO | WARNING | ERROR. Default INFO.
MCP_FSSP_LOG_LEVEL=INFO
